{
  "name": "admin",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "preinstall": "node -e \"var a=process.env.npm_config_user_agent||'';if(a&&!a.startsWith('bun')){console.error('\\x1b[31mUse bun, not npm/pnpm.\\x1b[0m');process.exit(1)}\"",
    "dev": "vite --port=3001",
    "build": "vite build && tsc --noEmit",
    "serve": "vite preview",
    "start": "vite",
    "generate:api": "orval",
    "check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "lint": "bun run lint:biome && bun run lint:ox && bun run lint:solid",
    "lint:biome": "biome check src",
    "lint:ox": "oxlint .",
    "lint:solid": "bun scripts/check-solid-patterns.ts",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "fix": "biome check --write src && oxlint --fix . && bun run format",
    "verify": "bun run lint && bun run format:check && bun run check && bun run test:run",
    "pre-commit": "bun run lint:solid && bun run format && bun run lint:biome"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/instrumentation-fetch": "^0.216.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/solid-query": "^5.100.7",
    "@tanstack/solid-router": "^1.169.1",
    "@tanstack/solid-router-devtools": "^1.166.13",
    "@thisbeyond/solid-dnd": "^0.7.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-polygon": "^3.0.1",
    "d3-selection": "^3.0.0",
    "postcss": "^8.5.13",
    "redaxios": "^0.5.1",
    "solid-flow": "^1.0.4",
    "solid-js": "^1.9.12",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bun": "^1.3.13",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/node": "^25.6.0",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.1",
    "orval": "^8.9.0",
    "oxlint": "^1.62.0",
    "simple-git-hooks": "^2.13.1",
    "solid-devtools": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.5"
  },
  "simple-git-hooks": {
    "pre-commit": "cd frontend && bun run pre-commit"
  }
}
